FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-secure-secret-key

# Database Configuration
# Dev/Test: sqlite:///instance/app.db
# Prod: mysql+pymysql://user:password@host:port/dbname
DATABASE_URL=sqlite:///app.db

# Microsoft OAuth2 Configuration
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/callback
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

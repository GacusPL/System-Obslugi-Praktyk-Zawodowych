FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=replace-with-a-secure-secret-key

# Database Configuration
# Dev/Test: sqlite:///instance/app.db
# Prod: mysql+pymysql://user:password@host:port/dbname
DATABASE_URL=sqlite:///app.db

# Microsoft OAuth2 Configuration
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/callback # Docker: 80, Local: 5000
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# ============================================================
# Docker (docker compose czyta ten plik z katalogu projektu)
# ============================================================
# Baza MariaDB w docker-compose:
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=sopz
MYSQL_USER=sopz_user
MYSQL_PASSWORD=sopz_password

# W dockerze aplikacja stoi za nginx na :80, więc redirect URI to:
#   MICROSOFT_REDIRECT_URI=http://localhost/auth/callback
# (musi być identyczny jak w Azure App registration)

# E2E=true włącza logowanie mock (bypass OAuth) także w kontenerze.
# Tylko do testów!
E2E=False
